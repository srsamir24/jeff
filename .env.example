# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Freepik / Magnific AI Studio
# Get your API key from https://www.freepik.com/developers (or the Magnific dashboard).
FREEPIK_API_KEY=
# Base host for the API. Leave as the default unless told otherwise.
FREEPIK_BASE_URL=https://api.freepik.com
# Random secret appended to the webhook callback URL (?token=...) so only Freepik can post results.
# Only used in production where the app is reachable on a public URL.
FREEPIK_WEBHOOK_SECRET=
